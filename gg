### 📋 **قاعدة البيانات المثالية (مستوحاة من Airbnb)**

```prisma
model User {
  id              String      @id @default(cuid())
  
  // === معلومات أساسية ===
  email           String?     @unique
  phone           String?     @unique
  name            String?
  avatar          String?
  
  // === كلمة المرور (اختيارية) ===
  passwordHash    String?     // null إذا استخدم OAuth فقط
  
  // === OAuth Providers ===
  googleId        String?     @unique
  appleId         String?     @unique
  facebookId      String?     @unique
  
  // === التحقق ===
  emailVerified   DateTime?
  phoneVerified   DateTime?
  
  // === الدور ===
  role            UserRole    @default(GUEST)
  isHost          Boolean     @default(false)  // يصبح true عند إضافة أول إقامة
  
  // === حالة الحساب ===
  status          UserStatus  @default(ACTIVE)
  
  // === معلومات المضيف (تُملأ عند إضافة أول إقامة) ===
  hostSince       DateTime?   // تاريخ أصبح مضيفاً
  hostAbout       String?
  hostResponseRate  Float?    @default(0)
  hostResponseTime  Int?      // بالدقائق
  
  // === الجلسات ===
  sessions        Session[]
  
  // === التاريخ ===
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  lastLoginAt     DateTime?
}

model Session {
  id            String    @id @default(cuid())
  token         String    @unique
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  
  // Remember Me
  isPersistent  Boolean   @default(false)
  
  // أمان
  ipAddress     String?
  userAgent     String?
  deviceInfo    String?
  
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  lastAccessed  DateTime  @default(now())
}

model OTPCode {
  id             String   @id @default(cuid())
  phone          String
  code           String
  purpose        String   // login, verify_phone, reset_password
  expiresAt      DateTime
  used           Boolean  @default(false)
  failedAttempts Int      @default(0)
  createdAt      DateTime @default(now())
  
  @@index([phone, createdAt])
}
```

